
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description Controls access to user profiles.
     * @path /users/{userId}
     * @allow (create) - Authenticated user can create their own profile if the userId matches their auth.uid.
     * @allow (get) - Authenticated user can read profiles.
     * @allow (list) - Admins can list users.
     * @allow (update, delete) - Authenticated user can only access their own profile.
     * @principle Enforces document ownership for updates/deletes.
     */
    match /users/{userId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }
      function isAdmin() {
          return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }

      allow create: if isOwner();
      allow get: if request.auth != null;
      allow list: if isAdmin();
      allow update, delete: if isOwner();
    }

    /**
     * @description Controls access to exams.
     * @path /exams/{examId}
     * @principle Teachers can create exams. Public can read them for reports. Only owner-teachers can update/delete.
     */
    match /exams/{examId} {
      allow get, list: if true;

      allow create: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
                     && request.resource.data.teacherId == request.auth.uid;

      allow update, delete: if request.auth != null && resource.data.teacherId == request.auth.uid;
    }


    /**
     * @description Controls access to questions within an exam.
     * @path /exams/{examId}/questions/{questionId}
     * @principle Owner-teacher can manage questions. Public can read them for reports.
     */
    match /exams/{examId}/questions/{questionId} {
        allow get, list: if true;

        allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/exams/$(examId)).data.teacherId == request.auth.uid;
    }


    /**
     * @description Controls access to student exams results and answers.
     * @path /studentExams/{studentExamId}
     * @principle Students own their exam attempts. Reports are public. Teachers can view results.
     */
    match /studentExams/{studentExamId} {
        // A student can create their own exam record.
        allow create: if request.auth != null && request.resource.data.studentId == request.auth.uid;

        // Allow public read for individual reports via direct link.
        allow get: if true;

        // Allow list queries under two conditions:
        // 1. A student is querying for their own results.
        // 2. A teacher is querying for results of an exam they own.
        allow list: if request.auth != null && (
            (request.query.where.studentId == request.auth.uid) ||
            (get(/databases/$(database)/documents/exams/$(request.query.where.examId)).data.teacherId == request.auth.uid)
        );

        // A student can update their own record, a teacher of the exam can also update it (e.g. for manual grading).
        allow update: if request.auth != null && 
          (request.auth.uid == resource.data.studentId || 
           get(/databases/$(database)/documents/exams/$(resource.data.examId)).data.teacherId == request.auth.uid);
           
        // Only the student can delete their own exam record.
        allow delete: if request.auth != null && request.auth.uid == resource.data.studentId;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    // Media files for exams
    match /exam-media/{examId}/{fileName} {
      // Any authenticated user can read (download) the media.
      allow read: if true;
      
      // Only authenticated teachers can write (upload, update, delete) files.
      // We also add some constraints on the file type and size.
      allow write: if request.auth != null &&
                    exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' &&
                    request.resource.size < 5 * 1024 * 1024 && // Max 5MB
                    (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('video/.*'));
    }
  }
}
